{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", "group:allNonMajor"],
  "mode": "full",
  "labels": ["dependencies"],
  "semanticCommitScope": "",
  "minimumReleaseAge": "7 days",
  "packageRules": [
    {
      "matchPackageNames": ["typescript"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    }
  ]
}
