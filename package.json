{
  "name": "ralphai",
  "version": "0.7.1",
  "description": "Autonomous task runner for AI coding agents",
  "type": "module",
  "bin": {
    "ralphai": "./bin/cli.mjs"
  },
  "files": [
    "dist",
    "bin",
    "skills"
  ],
  "scripts": {
    "build": "obuild",
    "dev": "bun src/cli.ts",
    "test": "bun scripts/test.ts",
    "test:fast": "bun scripts/test.ts --fast",
    "type-check": "tsc --noEmit",
    "format": "prettier --write 'src/**/*.ts'",
    "dogfood": "obuild && node bin/cli.mjs"
  },
  "keywords": [
    "cli",
    "ai-agents",
    "autonomous",
    "task-runner",
    "ralphai",
    "opencode",
    "claude-code",
    "codex",
    "gemini-cli",
    "aider",
    "goose",
    "kiro",
    "amp"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mfaux/ralphai.git"
  },
  "homepage": "https://github.com/mfaux/ralphai#readme",
  "bugs": {
    "url": "https://github.com/mfaux/ralphai/issues"
  },
  "author": "mfaux",
  "license": "MIT",
  "devDependencies": {
    "@clack/prompts": "^0.11.0",
    "@types/bun": "latest",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.14",
    "ink": "^6.8.0",
    "jiti": "^2.6.1",
    "obuild": "^0.4.22",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.10"
}
